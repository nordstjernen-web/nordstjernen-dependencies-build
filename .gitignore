# Generated Meson cross-files (produced by android/scripts/gen-cross-files.sh;
# they embed absolute, machine-specific NDK and sysroot paths).
/android/cross/*.cross

# Build scratch and download cache.
/android/.build/
/android/.cache/

# Installed sysroots / packaged artifacts.
/android/sysroot/
/sysroot/
/artifact/

# Generated Meson cross-files (produced by ios/scripts/gen-cross-files.sh;
# they embed absolute, machine-specific SDK paths).
/ios/cross/*.cross

# iOS build scratch, download cache and installed sysroots.
/ios/.build/
/ios/.cache/
/ios/sysroot/

# Linux build scratch, download cache and installed GTK overlay.
/linux/.build/
/linux/.cache/
/linux/sysroot/
